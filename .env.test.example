# .env.test.example — salin ke .env.test untuk menjalankan test
# JANGAN gunakan nilai ini di production!
NODE_ENV=test

# Ganti dengan koneksi database test Anda
DATABASE_URL="mysql://digilib_user:password@localhost:3306/digilib_unismu_test"

PORT=5001

# Nilai ini HANYA untuk test — boleh tetap seperti ini
JWT_SECRET=test_jwt_secret_yang_cukup_panjang_minimal_32_karakter_xxxx
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test_refresh_secret_yang_cukup_panjang_minimal_32_karakter_yyyy
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3000
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=5
LOG_LEVEL=silent
