# ─────────────────────────────────────────────────────────────────────────────
# Digilib UNISMU — Environment Configuration v3
# Salin ke .env dan isi sesuai environment Anda.
# JANGAN commit file .env ke repository!
# ─────────────────────────────────────────────────────────────────────────────

# ── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL="mysql://digilib_user:GANTI_PASSWORD@localhost:3306/digilib_unismu"

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_STRING_ACAK_MINIMAL_32_KARAKTER_AAAAAAAAAAAAAAAA
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=GANTI_DENGAN_STRING_ACAK_LAIN_MINIMAL_32_KARAKTER_BBBBBBBBBB
JWT_REFRESH_EXPIRES_IN=30d

# ── UPLOAD ────────────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=20

# ── CORS ──────────────────────────────────────────────────────────────────────
# Pisahkan dengan koma jika lebih dari satu origin production
# localhost selalu diizinkan secara otomatis (untuk Swagger UI & developer tools)
FRONTEND_URL=http://localhost:3000,https://digilib.unismu.ac.id

# ── RATE LIMITING ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10

# ── LOGGING ───────────────────────────────────────────────────────────────────
LOG_DIR=./logs
LOG_LEVEL=info
