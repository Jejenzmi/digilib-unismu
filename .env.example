# ══════════════════════════════════════════════════════════════════════════════
# Digilib UNISMU — Konfigurasi Deployment
# Salin file ini ke .env dan isi nilai yang diperlukan
#
#   cp .env.example .env
#
# JANGAN commit file .env ke repository!
# ══════════════════════════════════════════════════════════════════════════════

# ── DATABASE ──────────────────────────────────────────────────────────────────
MYSQL_DATABASE=digilib_unismu
MYSQL_USER=digilib_user
MYSQL_PASSWORD=GANTI_PASSWORD_DB_ANDA
MYSQL_ROOT_PASSWORD=GANTI_ROOT_PASSWORD_ANDA
DB_PORT=3306

# ── JWT (WAJIB — generate dengan perintah di bawah) ───────────────────────────
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GANTI_DENGAN_STRING_ACAK_64_KARAKTER_AAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
JWT_REFRESH_SECRET=GANTI_DENGAN_STRING_ACAK_LAIN_64_KARAKTER_BBBBBBBBBBBBBBBB
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── SERVER ────────────────────────────────────────────────────────────────────
API_PORT=5000
FRONTEND_PORT=3000
NODE_ENV=production
LOG_LEVEL=info
MAX_FILE_SIZE_MB=50

# ── CORS ──────────────────────────────────────────────────────────────────────
# Ganti dengan domain production jika sudah deploy ke server
FRONTEND_URL=http://localhost:3000

# ── FRONTEND ─────────────────────────────────────────────────────────────────
# Ganti dengan URL API production jika sudah ada domain
VITE_API_URL=http://localhost:5000/api

# ── SMTP EMAIL ────────────────────────────────────────────────────────────────
# Gmail: host=smtp.gmail.com port=587 secure=false
#        user=akun@gmail.com pass=App_Password_dari_Google
# Mailtrap (testing): host=sandbox.smtp.mailtrap.io port=2525
# Biarkan kosong untuk nonaktifkan fitur email
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Perpustakaan UNISMU <perpustakaan@unismu.ac.id>

# ── MINIO OBJECT STORAGE ──────────────────────────────────────────────────────
# Aktif saat menggunakan docker-compose.prod.yml
# STORAGE_DRIVER=minio mengaktifkan penyimpanan ke MinIO
# STORAGE_DRIVER=local  menggunakan disk lokal (default)
STORAGE_DRIVER=local
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=GANTI_MINIO_SECRET_YANG_KUAT_2024
MINIO_BUCKET=digilib
# URL publik MinIO — ganti dengan domain production jika ada
MINIO_PUBLIC_URL=http://localhost:9000

# ── BACKUP ────────────────────────────────────────────────────────────────────
# Berapa hari backup disimpan sebelum otomatis dihapus
BACKUP_RETENTION_DAYS=7

# ── NGINX / PRODUCTION ────────────────────────────────────────────────────────
# Domain production (untuk konfigurasi HTTPS)
# DOMAIN=digilib.unismu.ac.id
