PORT=5000

# WAJIB: Ganti dengan string acak yang kuat (min. 32 karakter) di production
# Contoh cara membuat: openssl rand -base64 32
# Server akan menolak start jika nilai ini kurang dari 32 karakter atau masih berupa placeholder.
JWT_SECRET=GANTI_DENGAN_STRING_ACAK_MIN_32_KARAKTER_DI_PRODUCTION
JWT_EXPIRES_IN=7d

# Set ke 'production' untuk mengaktifkan serving frontend statis dan optimisasi production
NODE_ENV=development

# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Contoh production: postgresql://digilib_user:StrongPassword123@db.example.com:5432/digilib_unismu
DATABASE_URL=postgresql://user:password@localhost:5432/digilib_unismu

# Development: http://localhost:5173
# Production (jika backend & frontend dipisah): https://yourdomain.com
# Production (jika backend serve frontend langsung): tidak perlu CORS_ORIGIN (atau set sama dengan backend URL)
CORS_ORIGIN=http://localhost:5173
