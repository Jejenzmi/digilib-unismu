PORT=5000

# WAJIB: Ganti dengan string acak yang kuat (min. 32 karakter) di production
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Set ke 'production' untuk mengaktifkan serving frontend statis dan optimisasi production
NODE_ENV=development

DATABASE_URL=postgresql://user:password@localhost:5432/digilib_unismu

# Development: http://localhost:5173
# Production (jika backend & frontend dipisah): https://yourdomain.com
# Production (jika backend serve frontend): tidak perlu CORS_ORIGIN (atau set sama dengan backend URL)
CORS_ORIGIN=http://localhost:5173
